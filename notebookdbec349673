    "    random_state=42, device='cuda', tree_method='hist', **study.best_params\n",
    ")\n",
    "final_model.fit(X_train, y_train, sample_weight=sw_full)\n",
    "print(f\"\\nFinal model trained on {len(X_train)} rows (no resampling).\")"
