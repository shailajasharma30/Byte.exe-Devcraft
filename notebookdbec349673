    "\n",
    "    acc = accuracy_score(y_val, y_pred_val)\n",
    "    f1  = f1_score(y_val, y_pred_val, average='macro')\n",
    "    fold_acc.append(acc)\n",
    "    fold_f1.append(f1)\n",
