    "# 1. Drop exact duplicates\n",
    "n_before_dedup = len(df)\n",
    "df = df.drop_duplicates()\n",
    "df = df.reset_index(drop=True)\n",
    "print(f\"Duplicate rows removed: {n_before_dedup - len(df)}\")\n",
    "\n",
    "# 2. Encode RiskLevel — explicit map, no LabelEncoder\n",
    "risk_map = {'low risk': 0, 'mid risk': 1, 'high risk': 2}\n",
    "df['RiskLevel'] = df['RiskLevel'].map(risk_map)\n",
    "print(f\"\\nEncoded RiskLevel values: {sorted(df['RiskLevel'].unique())}\")\n",
    "\n",
    "# 3. IQR outlier removal on SystolicBP and BS only\n",
    "n_before_outlier = len(df)\n",
    "for col in ['SystolicBP', 'BS']:\n",
    "    Q1, Q3 = df[col].quantile(0.25), df[col].quantile(0.75)\n",
    "    IQR = Q3 - Q1\n",
    "    lower, upper = Q1 - 1.5 * IQR, Q3 + 1.5 * IQR\n",
    "    df = df[(df[col] >= lower) & (df[col] <= upper)]\n",
    "\n",
    "df = df.reset_index(drop=True)\n",
    "print(f\"Outlier rows removed: {n_before_outlier - len(df)}\")\n",
    "\n",
    "# 4. Final shape\n",
    "print(f\"\\nFinal dataset shape after cleaning: {df.shape}\")\n",
    "print(f\"Class distribution post-clean:\\n{df['RiskLevel'].value_counts().sort_index()}\")"
   ]
