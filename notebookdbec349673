    "explainer   = shap.TreeExplainer(final_model)\n",
    "shap_raw    = explainer.shap_values(X_test)\n",
    "\n",
    "# Normalize output: handle both old (list) and new (3D array) SHAP formats\n",
    "if isinstance(shap_raw, np.ndarray) and shap_raw.ndim == 3:\n",
    "    # New format: (n_samples, n_features, n_classes) → convert to list\n",
    "    shap_values = [shap_raw[:, :, i] for i in range(shap_raw.shape[2])]\n",
    "else:\n",
    "    # Old format: list of (n_samples, n_features) arrays\n",
    "    shap_values = shap_raw\n",
    "\n",
    "print(f\"SHAP arrays: {len(shap_values)} classes | shape per class: {shap_values[0].shape}\")\n",
    "# Expected: 3 classes | shape: (n_test, 10)\n",
    "\n",
    "# 1. Feature importance bar plot — High Risk class\n",
    "shap.summary_plot(shap_values[2], X_test, plot_type='bar', plot_size=(9, 5))\n",
    "\n",
    "# 2. Waterfall for first true High Risk patient\n",
    "high_risk_indices = np.where(y_test.values == 2)[0]\n",
    "hr_idx = high_risk_indices[0]\n",
    "\n",
    "explanation = shap.Explanation(\n",
    "    values       = shap_values[2][hr_idx],\n",
    "    base_values  = explainer.expected_value[2] if hasattr(explainer.expected_value, '__len__') else explainer.expected_value,\n",
    "    data         = X_test.iloc[hr_idx].values,\n",
    "    feature_names= list(X_test.columns)\n",
    ")\n",
    "shap.plots.waterfall(explanation)\n",
    "\n",
    "# 3. Top-3 feature driver function\n",
    "def get_top3_features(i, predicted_class):\n",
    "    patient_shap = shap_values[predicted_class][i]\n",
    "    top3_idx     = np.argsort(np.abs(patient_shap))[-3:][::-1]\n",
    "    return list(zip(X_test.columns[top3_idx].tolist(), patient_shap[top3_idx].tolist()))\n",
    "\n",
    "pred_class_for_hr = int(final_model.predict(X_test.iloc[[hr_idx]])[0])\n",
    "for feat, score in get_top3_features(hr_idx, pred_class_for_hr):\n",
    "    print(f\"  {feat:<18} SHAP = {score:+.4f}\")"
